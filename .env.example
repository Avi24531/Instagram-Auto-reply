# Copy this file to .env and fill in your real values.
# Never commit your actual .env file.

# Instagram / Meta Graph API
INSTAGRAM_VERIFY_TOKEN=your_webhook_verify_token
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Google Gemini
GOOGLE_GEMINI_API_KEY=your_gemini_api_key

# Google Sheets (OAuth credentials configured in n8n, not env vars,
# but documented here for setup reference)
GOOGLE_SHEETS_DOCUMENT_ID=your_google_sheet_id
GOOGLE_SHEETS_SHEET_NAME=your_sheet_name
